epoll + timerfd 启动成功，每1秒触发一次...
✅ 定时事件触发！超时次数：1
//////////////////////////////////
#include <stdio.h>
#include <stdlib.h>
#include <sys/timerfd.h>
#include <sys/epoll.h>
#include <unistd.h>
#include <stdint.h>

// 定时周期：1秒 (秒，纳秒)
#define TIMER_SEC  1
#define TIMER_NSEC 0

int main() {
    int timer_fd, epoll_fd;
    struct epoll_event event, events[10];
    struct itimerspec ts;
    int n, i;

    // ========== 1. 创建 timerfd ==========
    // CLOCK_MONOTONIC：单调时钟，不受系统时间修改影响
    timer_fd = timerfd_create(CLOCK_MONOTONIC, 0);
    if (timer_fd < 0) {
        perror("timerfd_create failed");
        exit(1);
    }

    // ========== 2. 设置 timerfd 定时规则 ==========
    // 首次触发时间
    ts.it_value.tv_sec = TIMER_SEC;
    ts.it_value.tv_nsec = TIMER_NSEC;
    // 周期性触发时间（循环间隔）
    ts.it_interval.tv_sec = TIMER_SEC;
    ts.it_interval.tv_nsec = TIMER_NSEC;
    timerfd_settime(timer_fd, 0, &ts, NULL);

    // ========== 3. 创建 epoll 实例 ==========
    epoll_fd = epoll_create1(0);
    if (epoll_fd < 0) {
        perror("epoll_create1 failed");
        exit(1);
    }

    // ========== 4. 将 timerfd 加入 epoll 监听（监听可读事件） ==========
    event.events = EPOLLIN;    // 监听可读事件
    event.data.fd = timer_fd;  // 携带的fd数据
    epoll_ctl(epoll_fd, EPOLL_CTL_ADD, timer_fd, &event);

    printf("epoll + timerfd 启动成功，每1秒触发一次...\n");

    // ========== 5. epoll 循环监听 ==========
    while (1) {
        // 阻塞等待事件（-1=永久阻塞）
        n = epoll_wait(epoll_fd, events, 10, -1);
        if (n < 0) {
            perror("epoll_wait failed");
            break;
        }

        // 处理触发的事件
        for (i = 0; i < n; i++) {
            if (events[i].data.fd == timer_fd) {
                // 必须读取 timerfd，否则会一直触发事件
                uint64_t expirations;
                read(timer_fd, &expirations, sizeof(uint64_t));
                printf("✅ 定时事件触发！超时次数：%lu\n", expirations);
            }
        }
    }

    // 关闭资源
    close(timer_fd);
    close(epoll_fd);
    return 0;
}
///////////////////////
#include <stdio.h>
#include <stdlib.h>
#include <sys/timerfd.h>
#include <sys/epoll.h>
#include <unistd.h>
#include <stdint.h>

// 定义3个不同周期的定时器标识
#define MAX_EVENTS 5

// 创建定时器fd（通用函数：秒+纳秒）
int create_timerfd(int sec, int nsec) {
    int fd = timerfd_create(CLOCK_MONOTONIC, 0);
    struct itimerspec ts = {
        .it_value = {sec, nsec},    // 首次触发时间
        .it_interval = {sec, nsec}  // 循环周期
    };
    timerfd_settime(fd, 0, &ts, NULL);
    return fd;
}

int main() {
    int epoll_fd;
    // 3个独立的定时器fd
    int timer_100ms, timer_1s, timer_5s;
    struct epoll_event event, events[MAX_EVENTS];

    // ========== 1. 创建3个不同周期的定时器 ==========
    timer_100ms = create_timerfd(0, 100000000);  // 100毫秒
    timer_1s   = create_timerfd(1, 0);            // 1秒
    timer_5s   = create_timerfd(5, 0);            // 5秒

    // ========== 2. 创建epoll实例 ==========
    epoll_fd = epoll_create1(0);

    // 将3个定时器全部加入epoll监听
    event.events = EPOLLIN;  // 监听可读事件（定时器超时触发）
    
    event.data.fd = timer_100ms;
    epoll_ctl(epoll_fd, EPOLL_CTL_ADD, timer_100ms, &event);

    event.data.fd = timer_1s;
    epoll_ctl(epoll_fd, EPOLL_CTL_ADD, timer_1s, &event);

    event.data.fd = timer_5s;
    epoll_ctl(epoll_fd, EPOLL_CTL_ADD, timer_5s, &event);

    printf("epoll 单线程监听 3 个独立定时器\n");
    printf("=======================================\n");

    // ========== 3. epoll 主循环 ==========
    while (1)
    {
        // 阻塞等待：任意定时器超时，立即返回
        int n = epoll_wait(epoll_fd, events, MAX_EVENTS, -1);

        for (int i = 0; i < n; i++)
        {
            int fd = events[i].data.fd;
            uint64_t timeout_cnt;  // 存储超时次数

            // 读取定时器：必须读，否则会一直触发事件
            read(fd, &timeout_cnt, sizeof(uint64_t));

            // 100ms 定时器
            if (fd == timer_100ms) {
                printf("[100ms] 高频定时任务执行\n");
            }
            // 1秒 定时器
            else if (fd == timer_1s) {
                printf("[1秒] 定时任务执行\n");
            }
            // 5秒 定时器
            else if (fd == timer_5s) {
                printf("[5秒] 定时任务执行\n");
            }
        }
    }

    // 关闭资源（程序正常退出时执行）
    close(timer_100ms);
    close(timer_1s);
    close(timer_5s);
    close(epoll_fd);
    return 0;
}

